# FoundryOS environment variables
# Copy this file to .env locally.
# Do not commit .env.

# Optional: Notion integration for future registry/database sync
NOTION_API_KEY=
NOTION_REGISTRY_DATABASE_ID=
NOTION_LOG_DATABASE_ID=

# Optional: AI provider keys for future copy/spec enrichment
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional: deployment targets
GITHUB_TOKEN=
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Local defaults
FOUNDRYOS_DEFAULT_BRAND=Moonshine Capital
FOUNDRYOS_DEFAULT_DESIGN=moonshine-capital
FOUNDRYOS_OUTPUT_DIR=outputs
